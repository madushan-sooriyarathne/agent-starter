root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Shell: match the repo's hand-written 2-space, indented case bodies.
# shfmt reads these keys natively.
[*.sh]
indent_style = space
indent_size = 2
switch_case_indent = true
binary_next_line = false

[*.{json,md}]
indent_style = space
indent_size = 2
