{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/claude/format-on-save.sh\"",
            "timeout": 15,
            "statusMessage": "Formatting..."
          }
        ]
      }
    ]
  }
}
